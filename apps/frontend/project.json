{
  "name": "frontend",
  "projectType": "application",
  "sourceRoot": "apps/frontend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm build",
        "cwd": "apps/frontend"
      },
      "outputs": ["{workspaceRoot}/dist/apps/frontend"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run",
        "cwd": "apps/frontend"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t nx-demo-frontend:latest -f apps/frontend/Dockerfile ."
      }
    },
    "helm-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p dist/charts && helm package apps/frontend/charts/frontend -d dist/charts"
      }
    }
  }
}
