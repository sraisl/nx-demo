{
  "name": "backend",
  "projectType": "application",
  "sourceRoot": "apps/backend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/backend"
      },
      "outputs": ["{workspaceRoot}/apps/backend/target"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/backend"
      }
    },
    "docker-build": {
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "context": ".",
        "file": "apps/backend/Dockerfile",
        "tags": ["nx-demo-backend:latest"],
        "push": false
      }
    },
    "helm-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p dist/charts && helm package apps/backend/charts/backend -d dist/charts"
      }
    }
  }
}
