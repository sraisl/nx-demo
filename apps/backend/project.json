{
  "name": "backend",
  "projectType": "application",
  "sourceRoot": "apps/backend/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/backend"
      },
      "outputs": ["{workspaceRoot}/apps/backend/target"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/backend"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t nx-demo-backend:latest -f apps/backend/Dockerfile ."
      }
    },
    "helm-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p dist/charts && helm package apps/backend/charts/backend -d dist/charts"
      }
    }
  }
}
